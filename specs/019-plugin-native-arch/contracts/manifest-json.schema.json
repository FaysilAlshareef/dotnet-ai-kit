{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FaysilAlshareef/dotnet-ai-kit/specs/019-plugin-native-arch/contracts/manifest-json.schema.json",
  "title": "ManagedFile Manifest (.dotnet-ai-kit/manifest.json)",
  "description": "Manifest schema with v1 (legacy from feature 018) and v2 (new in feature 019) read compatibility. Current feature-018 writer at src/dotnet_ai_kit/cli.py:433-438 emits `schema_version: \"1\"` and lacks `host_owner` per file. Reader accepts both v1 and v2. Writer always emits v2 (schema_version=\"2\" + host_owner per file). Per research R11 and R16: v1 reader infers host_owner from path patterns (.claude/* → claude, .codex/* → codex, .cursor/* → cursor, .github/agents/*.agent.md or .github/copilot-instructions.md or .github/instructions/*.instructions.md → copilot, otherwise null).",
  "oneOf": [
    { "$ref": "#/$defs/ManifestV1" },
    { "$ref": "#/$defs/ManifestV2" }
  ],
  "$defs": {
    "ManifestV1": {
      "type": "object",
      "title": "Legacy v1 manifest (feature 018)",
      "required": ["schema_version", "plugin_version", "created_at", "files"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "1" },
        "plugin_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9\\.\\-]+)?$" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_upgrade_at": { "type": ["string", "null"], "format": "date-time" },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/ManagedFileV1" }
        }
      }
    },
    "ManifestV2": {
      "type": "object",
      "title": "New v2 manifest (feature 019)",
      "required": ["schema_version", "plugin_version", "created_at", "files"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "type": "string", "const": "2" },
        "plugin_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9\\.\\-]+)?$" },
        "created_at": { "type": "string", "format": "date-time" },
        "last_upgrade_at": { "type": ["string", "null"], "format": "date-time" },
        "last_migrate_at": { "type": ["string", "null"], "format": "date-time" },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/ManagedFileV2" }
        }
      }
    },
    "ManagedFileV1": {
      "type": "object",
      "title": "Legacy ManagedFile (no host_owner)",
      "required": ["path", "sha256", "plugin_version", "deployed_at"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "plugin_version": { "type": "string" },
        "deployed_at": { "type": "string", "format": "date-time" },
        "source_template": { "type": ["string", "null"] }
      }
    },
    "ManagedFileV2": {
      "type": "object",
      "title": "New ManagedFile (required host_owner)",
      "required": ["path", "sha256", "plugin_version", "deployed_at", "host_owner"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "plugin_version": { "type": "string" },
        "deployed_at": { "type": "string", "format": "date-time" },
        "source_template": { "type": ["string", "null"] },
        "host_owner": {
          "type": ["string", "null"],
          "enum": ["claude", "codex", "cursor", "copilot", null]
        }
      }
    }
  }
}
