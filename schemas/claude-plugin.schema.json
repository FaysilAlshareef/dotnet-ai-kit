{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/FaysilAlshareef/dotnet-ai-kit/specs/019-plugin-native-arch/contracts/claude-plugin.schema.json",
  "title": "Claude Code Plugin Manifest (dotnet-ai-kit)",
  "description": "Schema for .claude-plugin/plugin.json. All component-path fields use scalar relative paths per https://code.claude.com/docs/en/plugins-reference#component-path-fields. The `./` prefix is required. Object wrappers (e.g. {\"configFile\": \"...\"}) are NOT valid — use a plain string path. Arrays of individual SKILL.md files are NOT valid for `skills` — use a directory path.",
  "type": "object",
  "required": ["name", "version", "description"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "const": "dotnet-ai-kit" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9\\.\\-]+)?$" },
    "description": { "type": "string", "minLength": 1 },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "homepage": { "type": "string" },
    "repository": { "type": "string" },
    "license": { "type": "string" },
    "logo": { "type": "string" },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "skills": {
      "description": "Scalar relative path to skills directory per docs component-path-fields. Must be a string like './skills/' — NOT an array of SKILL.md paths.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+$" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\./.+$" } }
      ]
    },
    "commands": {
      "description": "Scalar relative path to commands directory or individual command files.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+$" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\./.+$" } }
      ]
    },
    "agents": {
      "description": "Scalar relative path to agents directory or individual agent files.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+$" },
        { "type": "array", "items": { "type": "string", "pattern": "^\\./.+$" } }
      ]
    },
    "hooks": {
      "description": "Scalar path to hooks config file (e.g. './hooks/hooks.json'). NOT an object wrapper.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+$" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "mcpServers": {
      "description": "Scalar path to MCP config file (e.g. './.mcp.json'). NOT an object wrapper with configFile.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+$" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "lspServers": {
      "description": "Scalar path to LSP config file (e.g. './.lsp.json'), array, or inline object.",
      "oneOf": [
        { "type": "string", "pattern": "^\\./.+\\.json$" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        ]
      }
    },
    "userConfig": { "type": "object" },
    "channels": { "type": "array", "items": { "type": "string" } },
    "outputStyles": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  }
}
