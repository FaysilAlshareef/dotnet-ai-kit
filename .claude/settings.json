      "Bash(coderabbit *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:devblogs.microsoft.com)",
      "WebFetch(domain:learn.microsoft.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-commit-lint.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-edit-format.sh"
          }
        ]
      },
      {
        "matcher": "Bash(dotnet new*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-scaffold-restore.sh"
          }
        ]
      }
    ]
  }
}
