#!/usr/bin/env bash
# Feature 019 / OOS-003 / commit 27 / T180: POSIX source-tree wrapper for
# dotnet-ai. End users should `pip install dotnet-ai-kit` (or
# `uv tool install dotnet-ai-kit`) and rely on the `[project.scripts]`
# entry point. This script exists for contributors working out of a
# fresh git clone where `pip install -e .` may not be run yet.
#
# Standalone-executable packaging (shiv / PyInstaller) is deferred to
# v1.1 per OOS-003.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
exec python -m dotnet_ai_kit.cli "$@"
